{
  "name": "farmacy-pos",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Farmacia - Punto de Venta",
  "main": "backend/main.js",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node backend/server.js",
    "client": "cd frontend && npm start",
    "build": "cd frontend && npm run build",
    "electron": "electron backend/main.js",
    "setup": "npm install && cd frontend && npm install",
    "db:init": "node database/init.js",
    "db:seed": "node database/seed.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.3.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0"
  },
  "author": "Farmacy POS",
  "license": "MIT"
}
